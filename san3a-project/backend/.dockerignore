# ── Dependencies ──────────────────────────────────────────────
# Never copy node_modules; they are OS-specific and huge
node_modules
npm-debug.log*
yarn-error.log*

# ── Dev / local config ────────────────────────────────────────
# The real secrets come from environment variables at runtime,
# not from a baked-in .env file
.env
.env.*
!.env.example

# ── Version control & editor noise ───────────────────────────
.git
.gitignore
.gitattributes
.DS_Store
.vscode
.idea
*.swp
*.swo

# ── Test / CI files ───────────────────────────────────────────
*.test.js
*.spec.js
__tests__
coverage
.nyc_output
jest.config.*

# ── Documentation & markdown ──────────────────────────────────
README.md
*.md

# ── Misc build artefacts ──────────────────────────────────────
dist
build
logs
*.log
